# Telegram Bot Configuration
# Create a bot via @BotFather on Telegram, then get your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Location to monitor (default: Castelo Branco)
MONITOR_LAT=39.8228
MONITOR_LNG=-7.4931
MONITOR_RADIUS_KM=50

# Polling interval in minutes (ANEPC updates every ~2 min)
POLL_INTERVAL_MIN=3
